# -----------------------------------------------------------------------------
# Current runtime: core app settings
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=market-research-mvp
# Production should set APP_URL to the canonical HTTPS URL.
# Preview deployments can omit it and let the app derive from VERCEL_URL.
APP_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info
TIMEZONE=Asia/Tokyo

# -----------------------------------------------------------------------------
# Current runtime: database
# -----------------------------------------------------------------------------
# Current Milestone 0/1 deployments do not require a database connection.
# Keep these set locally if you want to use Docker Compose or Prisma commands.
# Future database-backed runtime features on Vercel will need an external managed Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/market_research_mvp?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/market_research_mvp?schema=public

# -----------------------------------------------------------------------------
# Reserved for future milestones: auth / session
# -----------------------------------------------------------------------------
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Current runtime: feature flags
# -----------------------------------------------------------------------------
# Keep USE_MOCK_PROVIDERS=true for Development and Preview unless you are actively
# validating a live connector implementation in a later milestone.
USE_MOCK_PROVIDERS=true
ENABLE_X_CONNECTOR=false
ENABLE_AMAZON_CONNECTOR=false
ENABLE_KEEPA_CONNECTOR=false
ENABLE_CSV_IMPORT=true
ENABLE_SCHEDULED_JOBS=false
ENABLE_ADMIN_PAGE=true
MOCK_WATCH_KEYWORDS=limited release,restock,best seller,price spike
MOCK_WATCH_CATEGORIES=Collectibles,Audio,Gaming,Power


# -----------------------------------------------------------------------------
# Reserved for later live-adapter work: X
# -----------------------------------------------------------------------------
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_DEFAULT_QUERY_WINDOW_DAYS=7
X_DEFAULT_LOCALE=ja
X_REQUEST_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Reserved for later live-adapter work: Amazon / category source
# -----------------------------------------------------------------------------
# Keep this section generic until a specific approved integration is chosen.
AMAZON_MARKETPLACE=JP
AMAZON_REQUEST_TIMEOUT_MS=15000
AMAZON_DEFAULT_CATEGORY=
AMAZON_ASSOCIATE_TAG=
AMAZON_ACCESS_KEY_ID=
AMAZON_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Reserved for later live-adapter work: Keepa or price-history provider
# -----------------------------------------------------------------------------
KEEPA_API_KEY=
KEEPA_DOMAIN=co.jp
KEEPA_REQUEST_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Reserved for future milestones: job runner / scheduling
# -----------------------------------------------------------------------------
JOB_CONCURRENCY=2
JOB_BATCH_SIZE=50
JOB_RETRY_LIMIT=3
JOB_RETRY_BACKOFF_MS=2000
REFRESH_CRON=0 */6 * * *

# -----------------------------------------------------------------------------
# Current runtime: scoring defaults
# -----------------------------------------------------------------------------
DEFAULT_PLATFORM_FEE_RATE=0.10
DEFAULT_SHIPPING_COST=750
DEFAULT_OTHER_COST=0
TREND_SCORE_WEIGHT=1.0
BESTSELLER_SCORE_WEIGHT=1.0
MARGIN_SCORE_WEIGHT=1.0
RISK_SCORE_WEIGHT=1.0
HIGH_MARGIN_THRESHOLD=0.20

# -----------------------------------------------------------------------------
# Reserved for future milestones: caching / queue / background infra
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=900

# -----------------------------------------------------------------------------
# Reserved for future milestones: storage / exports
# -----------------------------------------------------------------------------
EXPORT_DIR=./tmp/exports
UPLOAD_DIR=./tmp/uploads

# -----------------------------------------------------------------------------
# Reserved for future milestones: observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Reserved for future milestones: email / notifications
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# 1) Do not commit a real .env file.
# 2) Vercel Preview and Production can safely run with mock mode enabled.
# 3) Live connector credentials may be stored in Vercel now, but Milestone 0/1 still falls back safely to mock data.
# 4) Add or remove variables as the implementation evolves, but keep this file in sync.
