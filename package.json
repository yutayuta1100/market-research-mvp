{
  "name": "market-research-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x || 22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint src tests next.config.ts tailwind.config.ts vitest.config.ts --max-warnings=0",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run tests/dashboard-smoke.test.ts tests/refresh-job.test.ts",
    "validate": "npm run lint && npm run typecheck && npm test",
    "ci": "npm run validate && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:format": "prisma format",
    "db:seed": "tsx prisma/seed.ts",
    "jobs:refresh": "tsx scripts/run-refresh.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "clsx": "^2.1.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
